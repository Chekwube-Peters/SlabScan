# --- Frontend (Vite exposes only VITE_* vars to the browser) ---
# Set to "true" to hit the live /api/value-card proxy instead of mock data.
VITE_USE_LIVE=false

# --- Server-side only (never exposed to the browser) ---
# Renaiss OS Index API credentials (partner tier).
RENAISS_KEY_ID=
RENAISS_SECRET=

# Anthropic API key for the taste-read layer (api/taste.js).
# If unset, api/taste.js falls back to a deterministic mock taste read.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for taste reads.
# ANTHROPIC_MODEL=claude-opus-4-8
